---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';

const posts = (await getCollection('post')).sort((a, b) => {
  const da = a.data.created_at || a.data.date || '';
  const db = b.data.created_at || b.data.date || '';
  return db.localeCompare(da);
});

function fmtYearMonth(d?: string) {
  if (!d) return '';
  const [y, m] = d.split('-');
  return `${y}.${m}`;
}
---
<BaseLayout title="jay" description="things about thinking" canonical="https://jayonthegreen.github.io/" ogType="website">
  <Nav />
  <ul style="padding: 0; margin: 0; list-style: none;">
    {posts.map((p) => {
      const date = p.data.created_at || p.data.date || '';
      return (
        <li style="list-style: none; margin: 0.5rem 0;">
          <a href={`/post/${p.id}/`} style="text-decoration: none;">
            {p.data.title || p.id}{' '}
            <p style="font-size: small; margin: 0; white-space: nowrap; text-overflow: ellipsis; overflow: hidden;">
              <span style="margin-right: 0.3rem;">
                {fmtYearMonth(date)}
              </span>
              {p.data.description}
            </p>
          </a>
        </li>
      );
    })}
  </ul>
</BaseLayout>
